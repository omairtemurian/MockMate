# ── AI ────────────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Get your key at https://elevenlabs.io (free tier: 10,000 chars/month)
VITE_ELEVENLABS_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Any long random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/mockmate

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to skip email verification (all accounts auto-verified)
# For Gmail: enable 2FA and create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# ── URLs ──────────────────────────────────────────────────────────────────────
# Used inside verification email links — change to your domain in production
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173


